{
  "name": "nitro-starter",
  "description": "My personal Nitro starter template",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "nitro build",
    "dev": "nitro dev",
    "preview": "nitro preview",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepare": "husky",
    "release:patch": "changelogen --patch --release && git push --follow-tags",
    "release:minor": "changelogen --minor --release && git push --follow-tags",
    "release:major": "changelogen --major --release && git push --follow-tags",
    "release:dry": "changelogen --dry",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "1.0.0-beta.22",
    "drizzle-query-logger": "^1.1.2",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "drizzle-kit": "1.0.0-beta.22",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nitro": "latest",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "latest"
  },
  "lint-staged": {
    "*.{js,ts,html,yaml,json,md}": "oxfmt",
    "*.{js,ts}": "oxlint"
  },
  "packageManager": "pnpm@11.5.2"
}
